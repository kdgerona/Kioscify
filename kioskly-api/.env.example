# Database Configuration
DATABASE_URL="postgresql://username:password@localhost:5432/kioskly_db?schema=public"

# JWT Configuration
JWT_SECRET="your-secret-key-here-change-in-production"
JWT_EXPIRES_IN=7d

# Server Configuration
PORT=3000
NODE_ENV=development

# Base URL for the application (used for generating absolute URLs for images)
# Development: http://localhost:3000
# Production: https://your-domain.com (e.g., https://kioscify.kdgerona.com)
BASE_URL=http://localhost:3000

# Rate limiting
# THROTTLE_GLOBAL_TTL=60000       # Global window in ms (default: 60000 = 1 min)
# THROTTLE_GLOBAL_LIMIT=100       # Max requests per global window (default: 100)
# THROTTLE_LOGIN_TTL=900000       # Login window in ms (default: 900000 = 15 min)
# THROTTLE_LOGIN_LIMIT=20         # Max login attempts per window (default: 20)

# CORS — comma-separated list of allowed origins; supports * wildcard (leave unset to allow all)
# ALLOWED_ORIGINS=https://kioscify.kdgerona.com,https://platform.kioscify.kdgerona.com,https://*.kioscify.kdgerona.com

# Redis — used for JWT token blacklist (logout/revocation)
REDIS_HOST=localhost
REDIS_PORT=6379
