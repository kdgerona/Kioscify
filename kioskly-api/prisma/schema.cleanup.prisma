// CLEANUP MIGRATION SCHEMA (§2.6 of the Menu/InventorySetup plan) — DO NOT
// deploy this until the full migration chain has run against production and
// the resulting backfill has been verified stable for 2-4 weeks:
//   1. migrate-catalog-to-menus.ts
//   2. migrate-inventory-to-setups.ts
//   3. migrate-inventory-template-ids.ts
//   4. backfill-inventory-record-item-ids.ts
//   5. backfill-inventory-snapshot-item-ids.ts
// Steps 3-5 all depend on InventoryItem's deprecated pre-InventorySetup
// fields (templateId, isTemplate, legacyCategory, etc.) to resolve old
// per-store-copy ids onto their shared master item — this schema drops those
// fields entirely, so running any of them after cutover is not possible.
// This file exists purely so it can be `prisma db push`'d against a restored
// post-migration copy of production data to confirm the tightened/required
// fields and dropped legacy fields don't collide or break anything, before
// it ever becomes the real schema.prisma. To cut over for real: rename this
// file to schema.prisma (replacing the additive one) once verified.
//
// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────────
// HIERARCHY: Kioscify (platform) → Company → Brand → Tenant (Store)
// ─────────────────────────────────────────────────────────────────────────────

model Company {
  id               String       @id @default(auto()) @map("_id") @db.ObjectId
  name             String
  slug             String       @unique // becomes subdomain: <slug>.kioscify.com
  description      String?
  logoUrl          String?
  contactEmail     String?
  contactPhone     String?
  address          String?
  themeColors      ThemeColors?
  isActive         Boolean      @default(true)
  canCreateBrands  Boolean      @default(false) // platform toggle: allow company to create brands
  canOnboardStores Boolean      @default(false) // platform toggle: allow company to create stores
  tombstone        Int          @default(0)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  brands           Brand[]
  stores           Tenant[]
  users            User[]

  @@map("companies")
}

model Brand {
  id                       String             @id @default(auto()) @map("_id") @db.ObjectId
  companyId                String             @db.ObjectId
  name                     String
  slug                     String
  description              String?
  logoUrl                  String?
  themeColors              ThemeColors?
  isActive                 Boolean            @default(true)
  enabledDeliveryPlatforms DeliveryPlatform[] @default([])
  preferenceLabel          String?
  tombstone                Int                @default(0)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  company         Company          @relation(fields: [companyId], references: [id], onDelete: Cascade)
  stores          Tenant[]
  users           User[]
  menus           Menu[]
  inventorySetups InventorySetup[]

  @@unique([companyId, slug])
  @@map("brands")
}

// ─────────────────────────────────────────────────────────────────────────────
// TENANT (Store) — operational unit under a Brand
// brandId / companyId are nullable during migration; required after
// slug is unique within a company+brand (see @@unique below)
// ─────────────────────────────────────────────────────────────────────────────

model Tenant {
  id                       String             @id @default(auto()) @map("_id") @db.ObjectId
  brandId                  String?            @db.ObjectId
  companyId                String?            @db.ObjectId
  name                     String
  slug                     String
  description              String?
  logoUrl                  String?
  contactEmail             String?
  contactPhone             String?
  address                  String?
  themeColors              ThemeColors?
  isActive                 Boolean            @default(true)
  enabledDeliveryPlatforms DeliveryPlatform[] @default([])
  tombstone                Int                @default(0)
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt

  brand   Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)

  priceTierId String?    @db.ObjectId
  priceTier   PriceTier? @relation(fields: [priceTierId], references: [id])

  // Menu / Inventory Setup assignment — nullable during rollout (a store can be
  // created and configured later; every catalog/inventory read must handle null
  // gracefully). Never denormalized onto the JWT — always resolved fresh from the
  // DB per request (mirrors priceTierId/PriceTiersService.resolveStoreTierId) so a
  // reassignment takes effect immediately, not on next login.
  menuId           String?         @db.ObjectId
  menu             Menu?           @relation(fields: [menuId], references: [id], onDelete: SetNull)
  inventorySetupId String?         @db.ObjectId
  inventorySetup   InventorySetup? @relation(fields: [inventorySetupId], references: [id], onDelete: SetNull)

  subscription StoreSubscription?

  users                     User[]
  userAccess                UserStoreAccess[]
  transactions              Transaction[]
  expenses                  Expense[]
  inventoryRecords          InventoryRecord[]
  inventoryOverrides        TenantInventoryOverride[]
  submittedReports          SubmittedReport[]
  submittedInventoryReports SubmittedInventoryReport[]
  userShiftReports          UserShiftReport[]
  userShiftInventoryReports UserShiftInventoryReport[]
  staffTimeLogs             StaffTimeLog[]
  heldOrders                HeldOrder[]

  @@unique([companyId, brandId, slug])
  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────────
// STORE SUBSCRIPTION — tracks subscription status and payment history
// ─────────────────────────────────────────────────────────────────────────────

model StoreSubscription {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String    @unique @db.ObjectId
  activatedAt DateTime? // null = pending activation, no billing yet
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tenant   Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payments SubscriptionPayment[]

  @@map("store_subscriptions")
}

model SubscriptionPayment {
  id             String    @id @default(auto()) @map("_id") @db.ObjectId
  subscriptionId String    @db.ObjectId
  month          DateTime // store-local first-of-month, normalized via getZonedMonthBounds(...).start
  paid           Boolean   @default(true)
  paidAt         DateTime?
  note           String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  subscription StoreSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@unique([subscriptionId, month])
  @@map("subscription_payments")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER-STORE ACCESS — enables STORE_ADMIN to manage multiple stores
// A user can have one UserStoreAccess record per store they are assigned to.
// CASHIER users always have exactly one store (via tenantId); this table is for
// STORE_ADMINs who own/manage multiple franchise locations.
// ─────────────────────────────────────────────────────────────────────────────

model UserStoreAccess {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  tenantId  String   @db.ObjectId
  role      Role     @default(STORE_ADMIN)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([userId, tenantId])
  @@map("user_store_access")
}

// ─────────────────────────────────────────────────────────────────────────────
// SESSION — one row per issued JWT, for login history/audit views.
// tenantId/companyId/brandId are denormalized from the JWT payload so list
// queries can filter without joining through User. Status is derived at read
// time (not stored): loggedOutAt set → ENDED, expiresAt < now → EXPIRED, else ACTIVE.
// ─────────────────────────────────────────────────────────────────────────────

model Session {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  userId      String    @db.ObjectId
  jti         String    @unique
  role        Role
  tenantId    String?   @db.ObjectId
  companyId   String?   @db.ObjectId
  brandId     String?   @db.ObjectId
  ipAddress   String?
  userAgent   String?
  loginAt     DateTime  @default(now())
  expiresAt   DateTime
  loggedOutAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([companyId])
  @@index([tenantId])
  @@map("sessions")
}

type ThemeColors {
  primary    String @default("#ea580c")
  secondary  String @default("#fb923c")
  accent     String @default("#fdba74")
  background String @default("#ffffff")
  text       String @default("#1f2937")
}

// ─────────────────────────────────────────────────────────────────────────────
// USER — scoped by role:
//   PLATFORM_ADMIN  → no tenantId / companyId (global scope)
//   COMPANY_ADMIN   → companyId set, tenantId null
//   STORE_ADMIN     → tenantId set, companyId + brandId also set
//   CASHIER         → tenantId set, companyId + brandId also set
// ADMIN kept temporarily for migration backwards-compat; will be removed after migration
// ─────────────────────────────────────────────────────────────────────────────

model User {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId          String?  @db.ObjectId // null for COMPANY_ADMIN and PLATFORM_ADMIN
  companyId         String?  @db.ObjectId // set for COMPANY_ADMIN; also set for store users
  brandId           String?  @db.ObjectId // set for store users (STORE_ADMIN, CASHIER)
  firstName         String   @default("")
  lastName          String   @default("")
  username          String
  password          String
  email             String
  role              Role     @default(CASHIER)
  isFirstLogin      Boolean  @default(true) // forces password change on first login
  isActive          Boolean  @default(true)
  tombstone         Int      @default(0) // soft delete — set once the account is disabled; username/email are freed on delete
  companyPrivileges Json? // null = owner (full access); { brands, analytics, users, settings } for restricted admins
  storePrivileges   Json? // null = owner (full access); { transactions, expenses, inventory, users, settings } for restricted store admins
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  tenant  Tenant?  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  company Company? @relation(fields: [companyId], references: [id], onDelete: Cascade)
  brand   Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)

  transactions                Transaction[]
  expenses                    Expense[]
  inventoryRecords            InventoryRecord[]
  submittedReports            SubmittedReport[]
  submittedInventoryReports   SubmittedInventoryReport[]
  userShiftReports            UserShiftReport[]
  userShiftInventoryReports   UserShiftInventoryReport[]
  staffTimeLogs               StaffTimeLog[]
  voidRequestsCreated         Transaction[]              @relation("VoidRequests")
  voidRequestsReviewed        Transaction[]              @relation("VoidReviews")
  expenseVoidRequestsCreated  Expense[]                  @relation("ExpenseVoidRequests")
  expenseVoidRequestsReviewed Expense[]                  @relation("ExpenseVoidReviews")
  storeAccess                 UserStoreAccess[]
  sessions                    Session[]
  heldOrders                  HeldOrder[]

  @@unique([tenantId, companyId, username])
  @@unique([tenantId, companyId, email])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────────────────────
// MENU — a Brand can have multiple Menus; a Store is assigned exactly one.
// Only Menu (and InventorySetup) are Brand-scoped containers. Everything
// nested under a Menu — Category, Size, Addon, Preference, Product, PriceTier
// — is directly owned by that Menu via its own menuId field, fully
// independent per menu; there is no shared-master + junction indirection
// (e.g. no MenuProduct) anywhere in this hierarchy. A product used on two
// menus is simply two separate Product rows.
// Assignment (Tenant.menuId) is resolved fresh per request, never cached in
// the JWT, so a reassignment takes effect immediately (see Tenant comment).
// ─────────────────────────────────────────────────────────────────────────────

model Menu {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  brandId     String   @db.ObjectId
  name        String
  description String?
  isActive    Boolean  @default(true)
  tombstone   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand       Brand        @relation(fields: [brandId], references: [id], onDelete: Cascade)
  stores      Tenant[]
  categories  Category[]
  sizes       Size[]
  addons      Addon[]
  preferences Preference[]
  products    Product[]
  priceTiers  PriceTier[]

  @@unique([brandId, name])
  @@map("menus")
}

// ─────────────────────────────────────────────────────────────────────────────
// CATALOG — owned by Menu (not Brand/Tenant). This is the cleanup-migration
// end state: legacy tenantId/brandId fields (and the Tenant/Brand back-relations
// that referenced them) have been dropped entirely, now that every row has been
// backfilled with menuId by migrate-catalog-to-menus.ts and verified stable.
//
// menuId is now required on Size/Addon/Preference/Product, each with a real
// @@unique([menuId, name]) index (Product excepted — no name-uniqueness
// requirement was ever specified for it).
//
// Category is the ONE exception that stays exactly as it was in the additive
// schema: menuId/inventorySetupId both remain nullable, PERMANENTLY, and
// neither gets a @@unique([..., name]) index — not just "not yet". A Category
// row has exactly one of these two scopes set (mirroring `type`), so a
// PRODUCT-typed row always has inventorySetupId == null and an INVENTORY-typed
// row always has menuId == null; MongoDB's unique index treats "missing" as
// one shared value, so e.g. two different InventorySetups' INVENTORY
// categories both named "Uncategorized" would collide on
// @@unique([menuId, name]) forever, not just during a migration window this
// cleanup pass resolves. Prisma has no schema-level partial/sparse index
// support on the MongoDB connector (confirmed via context7), so per-scope name
// uniqueness for Category stays a service-layer findFirst check indefinitely.
// If Category's dual-scope design ever needs a real DB-level uniqueness
// guarantee, it requires splitting into two models (e.g. ProductCategory /
// InventoryCategory) — out of scope for this cleanup pass.
// ─────────────────────────────────────────────────────────────────────────────

model Category {
  id               String        @id @map("_id")
  menuId           String?       @db.ObjectId // set when type == PRODUCT — stays nullable permanently, see comment above
  inventorySetupId String?       @db.ObjectId // set when type == INVENTORY — stays nullable permanently, see comment above
  type             CategoryType? @default(PRODUCT)
  name             String
  description      String?
  sequenceNo       Int           @default(0)
  tombstone        Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  menu           Menu?           @relation(fields: [menuId], references: [id], onDelete: Cascade)
  inventorySetup InventorySetup? @relation(fields: [inventorySetupId], references: [id], onDelete: Cascade)
  products       Product[]
  inventoryItems InventoryItem[]

  @@map("categories")
}

model Size {
  id             String   @id @map("_id")
  menuId         String   @db.ObjectId
  name           String
  priceModifier  Float
  foodpandaPrice Float?
  grabPrice      Float?
  volume         String?
  sequenceNo     Int      @default(0)
  tombstone      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menu             Menu              @relation(fields: [menuId], references: [id], onDelete: Cascade)
  productSizes     ProductSize[]
  transactionItems TransactionItem[]
  priceTiers       SizePriceTier[]

  @@unique([menuId, name])
  @@map("sizes")
}

model Addon {
  id             String   @id @map("_id")
  menuId         String   @db.ObjectId
  name           String
  price          Float
  foodpandaPrice Float?
  grabPrice      Float?
  sequenceNo     Int      @default(0)
  tombstone      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menu                  Menu                   @relation(fields: [menuId], references: [id], onDelete: Cascade)
  productAddons         ProductAddon[]
  transactionItemAddons TransactionItemAddon[]
  priceTiers            AddonPriceTier[]

  @@unique([menuId, name])
  @@map("addons")
}

model Preference {
  id         String   @id @map("_id")
  menuId     String   @db.ObjectId
  name       String
  isDefault  Boolean  @default(false)
  sequenceNo Int      @default(0)
  tombstone  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  menu               Menu                @relation(fields: [menuId], references: [id], onDelete: Cascade)
  productPreferences ProductPreference[]
  transactionItems   TransactionItem[]

  @@unique([menuId, name])
  @@map("preferences")
}

model Product {
  id             String   @id @map("_id")
  menuId         String   @db.ObjectId
  name           String
  price          Float
  foodpandaPrice Float?
  grabPrice      Float?
  categoryId     String
  image          String?
  tombstone      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  menu               Menu                @relation(fields: [menuId], references: [id], onDelete: Cascade)
  category           Category            @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  productSizes       ProductSize[]
  productAddons      ProductAddon[]
  productPreferences ProductPreference[]
  transactionItems   TransactionItem[]
  priceTiers         ProductPriceTier[]

  @@map("products")
}

model ProductSize {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String
  sizeId    String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  size      Size     @relation(fields: [sizeId], references: [id], onDelete: Cascade)

  @@unique([productId, sizeId])
  @@map("product_sizes")
}

model ProductAddon {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  productId String
  addonId   String
  createdAt DateTime @default(now())
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  addon     Addon    @relation(fields: [addonId], references: [id], onDelete: Cascade)

  @@unique([productId, addonId])
  @@map("product_addons")
}

model ProductPreference {
  id           String     @id @default(auto()) @map("_id") @db.ObjectId
  productId    String
  preferenceId String
  createdAt    DateTime   @default(now())
  product      Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  preference   Preference @relation(fields: [preferenceId], references: [id], onDelete: Cascade)

  @@unique([productId, preferenceId])
  @@map("product_preferences")
}

// ─────────────────────────────────────────────────────────────────────────────
// PRICE TIERS — Menu-scoped (not Brand-scoped): tier definitions are managed
// from inside a Menu's isolated workspace. A store's assigned tier must
// belong to the store's currently-assigned Menu (StoresService.update()
// clears priceTierId to null whenever menuId changes, since a tier from the
// old menu is meaningless under the new one).
// ─────────────────────────────────────────────────────────────────────────────

model PriceTier {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  menuId    String   @db.ObjectId
  name      String
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  menu              Menu               @relation(fields: [menuId], references: [id], onDelete: Cascade)
  stores            Tenant[]
  productPriceTiers ProductPriceTier[]
  sizePriceTiers    SizePriceTier[]
  addonPriceTiers   AddonPriceTier[]

  // Deferred in the additive schema (see schema.prisma's identical comment on
  // this model) because menuId was nullable there and Mongo's unique index
  // treats a missing field as one shared null — added back here now that
  // menuId is required, matching Size/Addon/Preference's identical pattern.
  @@unique([menuId, name])
  @@map("price_tiers")
}

model ProductPriceTier {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  productId      String // plain String to match Product.id (no @db.ObjectId)
  tierId         String @db.ObjectId
  price          Float
  foodpandaPrice Float?
  grabPrice      Float?

  product Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  tier    PriceTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([productId, tierId])
  @@map("product_price_tiers")
}

model SizePriceTier {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  sizeId         String // plain String to match Size.id (no @db.ObjectId)
  tierId         String @db.ObjectId
  priceModifier  Float
  foodpandaPrice Float?
  grabPrice      Float?

  size Size      @relation(fields: [sizeId], references: [id], onDelete: Cascade)
  tier PriceTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([sizeId, tierId])
  @@map("size_price_tiers")
}

model AddonPriceTier {
  id             String @id @default(auto()) @map("_id") @db.ObjectId
  addonId        String // plain String to match Addon.id (no @db.ObjectId)
  tierId         String @db.ObjectId
  price          Float
  foodpandaPrice Float?
  grabPrice      Float?

  addon Addon     @relation(fields: [addonId], references: [id], onDelete: Cascade)
  tier  PriceTier @relation(fields: [tierId], references: [id], onDelete: Cascade)

  @@unique([addonId, tierId])
  @@map("addon_price_tiers")
}

// ─────────────────────────────────────────────────────────────────────────────
// TRANSACTIONS — store-level (tenantId scoped), unchanged
// ─────────────────────────────────────────────────────────────────────────────

model Transaction {
  id              String         @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String         @db.ObjectId
  transactionId   String
  userId          String         @db.ObjectId
  clientId        String? // device-generated UUID for offline deduplication
  subtotal        Float
  total           Float
  paymentMethod   PaymentMethod
  paymentStatus   PaymentStatus  @default(COMPLETED)
  cashReceived    Float?
  change          Float?
  referenceNumber String?
  payments        PaymentSplit[] // populated only when paymentMethod == SPLIT; see comment above the type
  remarks         String?
  discountAmount  Float?
  timestamp       DateTime       @default(now())

  voidStatus          VoidStatus @default(NONE)
  voidReason          String?
  voidRequestedBy     String?    @db.ObjectId
  voidRequestedAt     DateTime?
  voidReviewedBy      String?    @db.ObjectId
  voidReviewedAt      DateTime?
  voidRejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User              @relation(fields: [userId], references: [id], onDelete: Restrict)
  voidRequester User?             @relation("VoidRequests", fields: [voidRequestedBy], references: [id], onDelete: SetNull)
  voidReviewer  User?             @relation("VoidReviews", fields: [voidReviewedBy], references: [id], onDelete: SetNull)
  items         TransactionItem[]

  @@unique([tenantId, transactionId])
  @@unique([tenantId, clientId]) // offline deduplication
  @@index([tenantId, createdAt])
  @@map("transactions")
}

model TransactionItem {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  transactionId  String   @db.ObjectId
  productId      String
  quantity       Int
  sizeId         String?
  preferenceId   String?
  subtotal       Float
  discountAmount Float?
  createdAt      DateTime @default(now())

  transaction Transaction            @relation(fields: [transactionId], references: [id], onDelete: Cascade)
  product     Product                @relation(fields: [productId], references: [id], onDelete: Restrict)
  size        Size?                  @relation(fields: [sizeId], references: [id], onDelete: Restrict)
  preference  Preference?            @relation(fields: [preferenceId], references: [id], onDelete: Restrict)
  addons      TransactionItemAddon[]

  @@index([transactionId])
  @@map("transaction_items")
}

model TransactionItemAddon {
  id                String   @id @default(auto()) @map("_id") @db.ObjectId
  transactionItemId String   @db.ObjectId
  addonId           String
  createdAt         DateTime @default(now())

  transactionItem TransactionItem @relation(fields: [transactionItemId], references: [id], onDelete: Cascade)
  addon           Addon           @relation(fields: [addonId], references: [id], onDelete: Restrict)

  @@unique([transactionItemId, addonId])
  @@map("transaction_item_addons")
}

// Embedded, not a relation: a split payment's legs are always read/written
// wholesale alongside their parent Transaction and never queried on their own,
// so every existing transaction.findMany(...) call site gets this back for
// free with no `include` changes needed.
type PaymentSplit {
  method          PaymentMethod
  amount          Float
  cashReceived    Float? // only when method == CASH
  change          Float? // only when method == CASH
  referenceNumber String? // only for non-cash methods
}

// ─────────────────────────────────────────────────────────────────────────────
// HELD ORDERS — store-level (tenantId scoped), ephemeral working state.
// A held order is a parked cart, not a sale — it never touches Transaction or
// sales reporting. Hard-deleted on resume/discard (no soft-delete/tombstone
// needed since it carries no audit/financial history). Also auto-purged daily —
// see HeldOrdersService.purgeStaleHeldOrders — anything left over from a
// previous business day is treated as abandoned.
// ─────────────────────────────────────────────────────────────────────────────

model HeldOrder {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId      String   @db.ObjectId
  heldByUserId  String   @db.ObjectId
  clientId      String? // device-generated UUID for offline dedup, mirrors Transaction.clientId
  customerLabel String?
  orderType     String   @default("regular") // 'regular' | 'foodpanda' | 'grab'
  subtotal      Float
  total         Float
  itemCount     Int
  items         Json // HeldOrderItem[] snapshot (productId/name/price, size, addons, preference, discount)
  createdAt     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  heldBy User   @relation(fields: [heldByUserId], references: [id], onDelete: Cascade)

  @@unique([tenantId, clientId])
  @@index([tenantId, createdAt])
  @@map("held_orders")
}

// ─────────────────────────────────────────────────────────────────────────────
// EXPENSES — store-level (tenantId scoped), unchanged
// ─────────────────────────────────────────────────────────────────────────────

model Expense {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String          @db.ObjectId
  userId      String          @db.ObjectId
  clientId    String? // device-generated UUID for offline deduplication
  description String
  amount      Float
  category    ExpenseCategory
  date        DateTime        @default(now())
  receipt     String?
  notes       String?

  voidStatus          VoidStatus @default(NONE)
  voidReason          String?
  voidRequestedBy     String?    @db.ObjectId
  voidRequestedAt     DateTime?
  voidReviewedBy      String?    @db.ObjectId
  voidReviewedAt      DateTime?
  voidRejectionReason String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant        Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user          User   @relation(fields: [userId], references: [id], onDelete: Restrict)
  voidRequester User?  @relation("ExpenseVoidRequests", fields: [voidRequestedBy], references: [id], onDelete: SetNull)
  voidReviewer  User?  @relation("ExpenseVoidReviews", fields: [voidReviewedBy], references: [id], onDelete: SetNull)

  @@unique([tenantId, clientId]) // offline deduplication
  @@index([tenantId, createdAt])
  @@map("expenses")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY SETUP — mirrors Menu exactly. A Brand can have multiple named,
// shared Inventory Setups; a Store is assigned one (nullable during rollout).
// InventoryItem is directly owned by an InventorySetup via its own
// inventorySetupId field — no shared-master + junction indirection (see Menu
// comment above; the same "only the container is Brand-scoped" rule applies
// here). TenantInventoryOverride lets one store locally tweak a shared item's
// thresholds without forking the setup itself.
//
// Reassignment-preservation guarantee: InventoryRecord.inventoryItemId always
// points at the same InventoryItem row, which is never hard-deleted — only
// tombstoned when removed from active use. So a store's stock-count history
// is structurally independent of both (a) an item being tombstoned out of
// active use, and (b) the store later being reassigned to a different
// InventorySetup entirely. The service layer surfaces such items as "legacy"
// — not in the active picker, excluded from low-stock alerts, but fully
// queryable.
// ─────────────────────────────────────────────────────────────────────────────

model InventorySetup {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  brandId     String   @db.ObjectId
  name        String
  description String?
  isActive    Boolean  @default(true)
  tombstone   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  brand      Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)
  stores     Tenant[]
  categories Category[]
  items      InventoryItem[]

  @@unique([brandId, name])
  @@map("inventory_setups")
}

// Per-store override of a shared InventoryItem's thresholds — lets one store
// tweak min-stock/expiration values locally without forking the item (which
// would defeat the point of the setup being shared/reusable).
model TenantInventoryOverride {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId               String   @db.ObjectId
  inventoryItemId        String   @db.ObjectId
  minStockLevel          Float?
  requiresExpirationDate Boolean?
  expirationWarningDays  Int?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@unique([tenantId, inventoryItemId])
  @@map("tenant_inventory_overrides")
}

// ─────────────────────────────────────────────────────────────────────────────
// INVENTORY ITEM — directly owned by one InventorySetup (mirrors Product's
// direct Menu ownership above). Never hard-deleted (tombstone only), since
// InventoryRecord history depends on it staying valid indefinitely — see the
// reassignment-preservation guarantee above.
//
// Cleanup migration end state: inventorySetupId is now required, and the
// deprecated pre-InventorySetup fields (brandId, tenantId, templateId,
// isTemplate, legacyCategory, minStockLevelCustomized,
// expirationWarningDaysCustomized) — needed only by
// migrate-inventory-template-ids.ts / migrate-inventory-to-setups.ts /
// backfill-inventory-record-item-ids.ts / backfill-inventory-snapshot-item-ids.ts
// while migrating — have been dropped. categoryId stays optional (an item can
// be uncategorized); no name-uniqueness index was ever specified for InventoryItem.
// ─────────────────────────────────────────────────────────────────────────────

model InventoryItem {
  id                     String   @id @default(auto()) @map("_id") @db.ObjectId
  inventorySetupId       String   @db.ObjectId
  name                   String
  unit                   String
  description            String?
  categoryId             String? // Category(type=INVENTORY), must belong to the same setup — enforced in the service layer
  minStockLevel          Float?
  requiresExpirationDate Boolean  @default(false)
  expirationWarningDays  Int?     @default(7)
  tombstone              Int      @default(0) // 1 = deprecated from active use, preserved for history (see guarantee above)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  inventorySetup   InventorySetup            @relation(fields: [inventorySetupId], references: [id], onDelete: Cascade)
  category         Category?                 @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  inventoryRecords InventoryRecord[]
  tenantOverrides  TenantInventoryOverride[]

  @@map("inventory_items")
}

model InventoryRecord {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId        String   @db.ObjectId
  inventoryItemId String   @db.ObjectId
  userId          String   @db.ObjectId
  clientId        String? // device-generated UUID for offline deduplication
  quantity        Float
  date            DateTime @default(now())
  notes           String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant        Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  inventoryItem InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@unique([tenantId, clientId]) // offline deduplication
  @@map("inventory_records")
}

// ─────────────────────────────────────────────────────────────────────────────
// REPORTS — store-level, unchanged
// ─────────────────────────────────────────────────────────────────────────────

model SubmittedReport {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  userId      String   @db.ObjectId
  reportDate  String // YYYY-MM-DD format
  submittedAt DateTime @default(now())
  periodStart DateTime
  periodEnd   DateTime

  salesSnapshot    SalesSnapshot
  expensesSnapshot ExpensesSnapshot
  summarySnapshot  SummarySnapshot

  transactionIds String[]
  expenseIds     String[]
  notes          String?
  clientId       String? // offline deduplication

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  // No @@unique([tenantId, clientId]) here — see UserShiftInventoryReport's
  // comment below for why; offline dedup for this model is enforced in
  // SubmittedReportsService.create() instead.
  @@index([tenantId, reportDate])
  @@index([tenantId, submittedAt])
  @@map("submitted_reports")
}

model UserShiftReport {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  userId      String   @db.ObjectId
  reportDate  String // YYYY-MM-DD (the calendar day this shift falls on)
  submittedAt DateTime @default(now())
  periodStart DateTime
  periodEnd   DateTime

  salesSnapshot    SalesSnapshot
  expensesSnapshot ExpensesSnapshot
  summarySnapshot  SummarySnapshot

  transactionIds String[]
  expenseIds     String[]
  notes          String?
  clientId       String? // offline deduplication (UUID per submission)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  // No @@unique([tenantId, clientId]) — see UserShiftInventoryReport's comment below.
  @@index([tenantId, reportDate])
  @@index([tenantId, userId])
  @@map("user_shift_reports")
}

model SubmittedInventoryReport {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  tenantId    String   @db.ObjectId
  userId      String   @db.ObjectId
  reportDate  String // YYYY-MM-DD format
  submittedAt DateTime @default(now())

  inventorySnapshot InventorySnapshot
  notes             String?
  clientId          String? // offline deduplication
  isShiftMirror     Boolean?          @default(false) // true for records mirrored from shift inventory reports

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  // No @@unique([tenantId, clientId]) — see UserShiftInventoryReport's comment below.
  @@index([tenantId, reportDate])
  @@index([tenantId, submittedAt])
  @@map("submitted_inventory_reports")
}

model UserShiftInventoryReport {
  id         String @id @default(auto()) @map("_id") @db.ObjectId
  tenantId   String @db.ObjectId
  userId     String @db.ObjectId
  reportDate String // YYYY-MM-DD

  inventorySnapshot InventorySnapshot

  notes    String?
  clientId String? // offline deduplication

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  submittedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  // Deliberately no @@unique([tenantId, clientId]) on this model or its three
  // report-snapshot siblings (SubmittedReport/UserShiftReport/
  // SubmittedInventoryReport). `clientId` is optional and, unlike
  // Transaction/Expense/HeldOrder/InventoryRecord (which share this exact
  // pattern), real production data has many legitimate documents per tenant
  // that never set it. MongoDB's unique index treats a missing field as one
  // shared "null" value across all documents, so a compound unique index here
  // would falsely collide the moment a tenant has two such documents — as
  // verified against a restored production copy (2026-07-10): every one of
  // these four collections failed `prisma db push` on exactly this collision
  // (submitted_reports/user_shift_reports/submitted_inventory_reports had
  // real multi-document collisions; user_shift_inventory_reports had none yet
  // but is structurally identical and would hit the same wall as data grows).
  // Prisma has no schema-level partial/sparse index for MongoDB to fix this
  // properly, and a hand-written partial index outside the schema isn't safe
  // either — `db push` treats schema.prisma as the sole source of truth for
  // indexes on this connector and can drop anything undeclared. So dedup for
  // all four models is enforced at the service layer instead (an explicit
  // findFirst-by-clientId check before create, mirroring the same check the
  // four working models above already do) — see */*.service.ts create().
  @@index([tenantId, reportDate])
  @@index([tenantId, userId])
  @@map("user_shift_inventory_reports")
}

