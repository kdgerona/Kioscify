# API Configuration
# Copy this file to .env and update with your actual values

# Base API URL for tenant endpoints
# In development, this is typically http://localhost:3000
# In production, replace with your actual API URL
EXPO_PUBLIC_API_URL=http://localhost:3000

# Storage/asset origin (nginx -> MinIO, port 80) — used to rewrite kioscify.localhost
# image/logo URLs (unreachable from emulators/physical devices) to something reachable.
# In production this isn't needed since the public domain resolves everywhere.
# EXPO_PUBLIC_STORAGE_URL=http://192.168.1.21
