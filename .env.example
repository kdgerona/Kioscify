# ================================
# Kioskly Docker Environment Configuration
# ================================
# Copy this file to .env and update with your values

# ================================
# MongoDB Configuration
# ================================
MONGO_ROOT_USERNAME=<MONGO_ROOT_USERNAME>
MONGO_ROOT_PASSWORD=<MONGO_ROOT_PASSWORD>
MONGO_DATABASE=<MONGO_DATABASE>

# ================================
# MinIO Object Storage
# ================================
MINIO_ROOT_USER=<MINIO_ROOT_USER>
MINIO_ROOT_PASSWORD=<MINIO_ROOT_PASSWORD>
MINIO_BUCKET=kioscify
# Public URL base used for stored file URLs (no trailing slash)
# Production: https://kioscify.com/storage
MINIO_PUBLIC_URL=<MINIO_PUBLIC_URL>

# ================================
# API Configuration
# ================================
JWT_SECRET=<JWT_SECRET>
JWT_EXPIRES_IN=<JWT_EXPIRES_IN>

# Base URL for the API (used for generating absolute URLs for images)
# IMPORTANT: This should match your domain (without /api/v1 suffix)
# Development: http://localhost
# Production: https://your-domain.com (e.g., https://kioscify.com)
BASE_URL=<BASE_URL>

# ================================
# Frontend Configuration
# ================================
# Replace with your domain or public IP (include /api/v1 suffix)
# Development: http://localhost/api/v1
# Production: https://your-domain.com/api/v1
NEXT_PUBLIC_API_URL=<NEXT_PUBLIC_API_URL>

# Root domain used by kioscify-company middleware for subdomain detection
# e.g., kioscify.com  (no protocol, no trailing slash)
PLATFORM_DOMAIN=<PLATFORM_DOMAIN>

# Base URL of the store portal — used by kioscify-company to build copy-link URLs
# Development: http://localhost:3000
# Production: https://your-store-portal-domain.com
NEXT_PUBLIC_STORE_PORTAL_BASE_URL=<NEXT_PUBLIC_STORE_PORTAL_BASE_URL>
